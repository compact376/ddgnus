# Stripe keys — get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe webhook secret — get from https://dashboard.stripe.com/webhooks (Signing secret)
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe price IDs — get from https://dashboard.stripe.com/products
STRIPE_PRICE_WELLNESS=price_...
STRIPE_PRICE_BOOK=price_...

# Your app's public URL (used for Stripe success/cancel redirects)
# Development:
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production:
# NEXT_PUBLIC_APP_URL=https://dgnus.com

# CORS — set to your frontend URL in production
# Development:
ALLOWED_ORIGIN=http://localhost:3000
# Production:
# ALLOWED_ORIGIN=https://dgnus.com

# Server port
PORT=8080
